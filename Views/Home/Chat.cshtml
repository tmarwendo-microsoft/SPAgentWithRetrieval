@{
    ViewData["Title"] = "Chat";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h2>Azure AI Chat Agent</h2>
            <p class="text-muted">Ask questions about your Microsoft 365 content</p>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="card" style="height: 70vh;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Chat</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clearChat">Clear Chat</button>
                </div>
                <div class="card-body d-flex flex-column">
                    <div id="messagesContainer" class="flex-grow-1 overflow-auto mb-3" style="max-height: calc(70vh - 120px);">
                        <ul id="messagesList" class="list-unstyled">
                            <li class="mb-2">
                                <div class="d-flex">
                                    <div class="bg-light rounded p-2">
                                        <strong>System:</strong> Welcome! Ask me questions about your Microsoft 365 content.
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="mt-auto">
                        <div class="input-group">
                            <input type="text" id="messageInput" class="form-control" placeholder="Type your message..." />
                            <button class="btn btn-primary" type="button" id="sendButton">Send</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat.js"></script>
}